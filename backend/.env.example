# LaunchCare gateway — copy to the box (or export) and fill in.

# Convex deployment this box reports to (cloud: https://<name>.convex.cloud)
CONVEX_URL=

# The organization this box serves (from agency:createOrganization)
ORG_ID=

# Novita LLM API key — https://novita.ai/settings/key-management
NOVITA_API_KEY=
# Override only if Novita changes their base URL
# NOVITA_BASE_URL=https://api.novita.ai/openai/v1

# Optional: gateway port (default 8787) and prompt version tag for run diffing
# PORT=8787
# PROMPT_VERSION=v0.1

# Optional: RUNNER=mock resolves every ticket as reply_only without LLM spend
# (plumbing tests / CI); RUNNER=hermes delegates to the Hermes profile.
# RUNNER=

# Demo/judging mode: serve EVERY org on the deployment from this one box
# (per-org Telegram pollers + demo-ticket queues). One box per tenant later.
# MULTI_ORG=1

# Tenant tool credentials (not needed in eval mode)
# Dodo Payments API key — billing verification/refunds. DODO_API_BASE
# defaults to https://live.dodopayments.com (use https://test.dodopayments.com for test mode).
DODO_API_KEY=
# DODO_API_BASE=
ELEVENLABS_KEY=
LINKUP_KEY=
ACTIONLAYER_TOKEN=
# Telegram is normally connected per-org from the app (main menu). This env
# token overrides the setting for THIS box's primary org only.
TELEGRAM_TOKEN=
